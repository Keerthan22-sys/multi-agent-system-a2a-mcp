# Copy to .env and fill in real values.

OPENAI_API_KEY=

# NewsApi.org — https://newsapi.org/register
NEWSAPI_KEY=

# OpenWeather — https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ExchangeRate-API — https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=

# Pexels — https://www.pexels.com/api/
PEXELS_API_KEY=

# .env.example — Day 11
# Copy to .env and fill in your secrets. The .env file is loaded by both
# the local Python services AND by docker-compose (via env_file: .env).

# ===== External API keys =====
OPENAI_API_KEY=
NEWS_API_KEY=
OPENWEATHER_API_KEY=
EXCHANGE_RATE_API_KEY=
PEXELS_API_KEY=

# ===== Day 8: Critic loop tuning =====
SYNAPSE_ENABLE_CRITIC=true
SYNAPSE_MAX_REVISIONS=2

# ===== Day 9: cost display =====
SYNAPSE_USD_TO_INR=84.0

# ===== Day 6/9/10: infrastructure endpoints =====
# Both have sane localhost defaults; docker-compose overrides these per-service.
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
# REDIS_URL=redis://localhost:6379

# ===== Day 11: service hosts =====
# Leave these unset for local dev (defaults to 0.0.0.0).
# docker-compose.yml sets them to service names (e.g. WORLD_DATA_HOST=world-data).
# WORLD_DATA_HOST=0.0.0.0
# FINANCE_HOST=0.0.0.0
# MEDIA_HOST=0.0.0.0
# MEMORY_HOST=0.0.0.0
# CONVERSATION_HOST=0.0.0.0
# ROUTER_HOST=0.0.0.0
# EVAL_HOST=0.0.0.0
# CRITIC_HOST=0.0.0.0
# CONTEXTUALIST_HOST=0.0.0.0
# SCOUT_HOST=0.0.0.0
# PUBLISHER_HOST=0.0.0.0
